# Binance API Configuration
# Get your keys at: https://www.binance.com/en/my/settings/api-management
# IMPORTANT: Enable IP whitelist and disable withdrawal permission
BINANCE_API_KEY=your_api_key_here
BINANCE_API_SECRET=your_api_secret_here

# Trading Mode: "simulation" or "live"
TRADING_MODE=simulation

# Optional: Binance Testnet (for pre-live validation)
# BINANCE_TESTNET_API_KEY=your_testnet_key
# BINANCE_TESTNET_API_SECRET=your_testnet_secret
