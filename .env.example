# ===========================================
# Crypto Triangular Arbitrage — API Keys
# ===========================================
# Copy this to .env and fill in your keys.
# NEVER commit .env to git.
#
# SECURITY:
# - Enable IP whitelist on all exchange API keys
# - Disable withdrawal permission
# - Use read-only keys for scanning (--live-scan --dry-run)

# --- Binance ---
BINANCE_API_KEY=
BINANCE_API_SECRET=

# --- Bybit ---
BYBIT_API_KEY=
BYBIT_API_SECRET=

# --- OKX ---
OKX_API_KEY=
OKX_API_SECRET=
OKX_PASSPHRASE=

# --- Trading Mode ---
# "simulation" = paper trading with simulated prices
# "live" = real orders with real money
TRADING_MODE=simulation
