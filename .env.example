# ===========================================
# Crypto Triangular Arbitrage — API Keys
# ===========================================
# Copy this to .env and fill in your keys.
# NEVER commit .env to git.
#
# SECURITY CHECKLIST (verify before going live):
# [x] Enable IP whitelist on all exchange API keys
# [x] DISABLE withdrawal permission on all API keys
# [x] Use read-only keys for scanning (--live-scan --dry-run)
# [x] Regenerate keys if they were ever exposed

# --- Binance ---
BINANCE_API_KEY=
BINANCE_API_SECRET=

# --- KuCoin ---
KUCOIN_API_KEY=
KUCOIN_API_SECRET=
KUCOIN_PASSPHRASE=

# --- Bybit (optional) ---
BYBIT_API_KEY=
BYBIT_API_SECRET=

# --- OKX (optional) ---
OKX_API_KEY=
OKX_API_SECRET=
OKX_PASSPHRASE=

# --- Trading Mode ---
# "simulation" = paper trading with simulated prices
# "live" = real orders with real money
TRADING_MODE=simulation
